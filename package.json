{
	"name": "rhubarb",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"predev": "rimraf .next",
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"test:ut": "vitest --project unit",
		"test:storybook": "vitest --project storybook",
		"test:all": "vitest",
		"storybook": "storybook dev -p 6006 --no-open",
		"build-storybook": "storybook build",
		"supa:start": "supabase start",
		"supa:stop": "supabase stop",
		"supa:reset": "supabase db reset",
		"supa:types": "supabase gen types typescript --local > ./src/backend/types/supabase.ts",
		"supa:migrate": "supabase migration up",
		"testdata:generate": "node ./scripts/generate-test-data.mjs",
		"testdata:import": "node ./scripts/import-test-data.mjs",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.43",
		"@ai-sdk/react": "^3.0.118",
		"@emotion/react": "^11.14.0",
		"@hookform/resolvers": "^5.2.2",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.87.1",
		"ai": "^6.0.116",
		"classnames": "^2.5.1",
		"dayjs": "^1.11.19",
		"material-symbols": "^0.40.2",
		"next": "^16.1.7",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-hook-form": "^7.71.1",
		"react-toastify": "^11.0.5",
		"uuid": "^13.0.0",
		"zod": "^4.1.13"
	},
	"pnpm": {
		"overrides": {
			"rollup@<4.59.0": "^4.59.0",
			"tar@<7.5.11": "^7.5.11",
			"ajv@6": "^6.14.0",
			"minimatch@3": "^3.1.4",
			"minimatch@9": "^9.0.7",
			"minimatch@10": "^10.2.3",
			"flatted@<3.4.0": ">=3.4.0",
			"flatted@<=3.4.1": ">=3.4.2",
			"brace-expansion@<1.1.13": "1.1.13",
			"brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
			"brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"yaml@>=1.0.0 <1.10.3": ">=1.10.3",
			"yaml@>=2.0.0 <2.8.3": ">=2.8.3",
			"next@>=16.0.0-beta.0 <16.2.3": ">=16.2.3"
		}
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@storybook/addon-a11y": "^10.2.8",
		"@storybook/addon-docs": "^10.2.8",
		"@storybook/addon-mcp": "^0.2.2",
		"@storybook/addon-vitest": "^10.2.8",
		"@storybook/nextjs-vite": "^10.2.8",
		"@tailwindcss/postcss": "^4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.2",
		"@vitest/browser-playwright": "^4.0.15",
		"@vitest/coverage-v8": "^4.0.15",
		"babel-plugin-react-compiler": "1.0.0",
		"daisyui": "^5.5.8",
		"eslint": "^9",
		"eslint-config-next": "16.0.8",
		"eslint-plugin-storybook": "^10.2.8",
		"husky": "^9.1.7",
		"jsdom": "^27.3.0",
		"lint-staged": "^16.2.7",
		"mockdate": "^3.0.5",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rimraf": "^6.1.2",
		"storybook": "^10.2.10",
		"supabase": "^2.75.5",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vite": "^7.3.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.15"
	}
}
